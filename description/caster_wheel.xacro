<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- user-defined parameters for the wheel -->
    <xacro:property name="wheel_radius" value="0.025"/>
    <xacro:property name="wheel_mass" value="0.1"/>

    <!-- wheel with user-defined parameters -->
    <xacro:macro name="robot_caster_wheel" params="parent child xyz">
        <!-- joint -->
        <joint name="${parent}_to_${child}_joint" type="fixed">
            <parent link="${parent}"/>
            <child link="${child}"/>
            <origin xyz="${xyz}" rpy="0 0 0"/>
        </joint>

        <!-- link -->
        <link name="${child}">
            <!-- visual -->
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <sphere radius="${wheel_radius}"/>
                </geometry>
                <material name="green"/>
            </visual>

            <!-- collision -->
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <sphere radius="${wheel_radius}"/>
                </geometry>
            </collision>

            <!-- inertia -->
            <inertial>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <mass value="${wheel_mass}"/>
                <inertia ixx="${(2/5) * (wheel_mass) * (wheel_radius * wheel_radius)}"
                        ixy="0.0"
                        ixz="0.0"
                        iyy="${(2/5) * (wheel_mass) * (wheel_radius * wheel_radius)}"
                        iyz="0.0"
                        izz="${(2/5) * (wheel_mass) * (wheel_radius * wheel_radius)}"/>
            </inertial>
        </link>

        <gazebo reference="${child}">
            <material>Gazebo/Green</material>
            <mu1 value="0.001"/>
            <mu2 value="0.001"/>
        </gazebo>
    </xacro:macro>

</robot>