<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <!-- wheel with user-defined parameters -->
    <xacro:macro name="robot_wheel" params="parent child xyz rpy abc">
        <!-- joint -->
        <joint name="${parent}_to_${child}_joint" type="continuous">
            <parent link="${parent}"/>
            <child link="${child}"/>
            <origin xyz="${xyz}" rpy="${rpy}"/>
            <axis xyz="${abc}"/>
        </joint>

        <!-- link -->
        <link name="${child}">
            <!-- visual -->
            <visual>
               <!--<origin xyz="${xyz}"/>-->
                <geometry>
                    <cylinder radius="0.025" length="0.02"/>
                </geometry>
                <material name="blue"/>
            </visual>

            <!-- collision -->
            <collision>
                <!--<origin xyz="${xyz}"/>-->
                <geometry>
                    <cylinder radius="0.025" length="0.02"/>
                </geometry>
            </collision>

            <!-- inertia -->
            <inertial>
                <mass value="0.1"/>
                <inertia ixx="${(1/12) * (0.1) * ((3 * 0.025 * 0.025) + (0.02 * 0.02))}"
                        ixy="0.0"
                        ixz="0.0"
                        iyy="${(1/12) * (0.1) * ((3 * 0.025 * 0.025) + (0.02 * 0.02))}"
                        iyz="0.0"
                        izz="${(1/2) * (0.1) * (0.025 * 0.025)}"/>
            </inertial>
        </link>
    </xacro:macro>

</robot>