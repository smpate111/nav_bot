<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <!-- pillar with user-defined parameters -->
    <xacro:macro name="robot_pillar" params="parent child xyz rpy">
        <!-- joint -->
        <joint name="${child}_joint" type="fixed">
            <parent link="${parent}"/>
            <child link="${child}"/>
            <origin xyz="${xyz}" rpy="${rpy}"/>
        </joint>

        <!-- link -->
        <link name="${child}">
            <!-- visual -->
            <visual>
               <!--<origin xyz="${xyz}"/>-->
                <geometry>
                    <cylinder radius="0.005" length="0.0508"/>
                </geometry>
                <material name="white"/>
            </visual>

            <!-- collision -->
            <collision>
                <!--<origin xyz="${xyz}"/>-->
                <geometry>
                    <cylinder radius="0.005" length="0.0508"/>
                </geometry>
            </collision>

            <!-- inertia -->
            <inertial>
                <mass value="0.1"/>
                <inertia ixx="${(1/12) * (0.1) * ((3 * 0.1143 * 0.1143) + (0.005 * 0.005))}"
                        ixy="0.0"
                        ixz="0.0"
                        iyy="${(1/12) * (0.1) * ((3 * 0.1143 * 0.1143) + (0.005 * 0.005))}"
                        iyz="0.0"
                        izz="${(1/2) * (0.1) * (0.1143 * 0.1143)}"/>
            </inertial>
        </link>
    </xacro:macro>

</robot>